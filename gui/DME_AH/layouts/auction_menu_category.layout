PanelWidgetClass CategoryRoot {
 size 1 0.06
 color 0 0 0 0
 style DayZDefaultPanel
 ignorepointer 0
 {
  ButtonWidgetClass btnExpand {
   position 0 0
   size 16 16
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   valign center_ref
   text ">"
   font "gui/fonts/metron16bold"
   color 0.8 0.8 0.8 1
   style ""
  }
  ImageWidgetClass imgIcon {
   position 20 0
   size 24 24
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   valign center_ref
   image0 "set:dayz_gui image:icon_gear"
   ignorepointer 1
   "src alpha" 1
   "clamp mode" clamp
   "stretch mode" stretch_w_h
  }
  TextWidgetClass txtName {
   position 50 0
   size 0.6 1
   hexactpos 1
   vexactpos 0
   hexactsize 1
   vexactsize 0
   font "gui/fonts/metron16bold"
   color 1 1 1 1
   text "Category"
   "text halign" left
   "text valign" center
   "exact text" 1
   ignorepointer 0
  }
  TextWidgetClass txtCount {
   position 0.7 0
   size 0.28 1
   font "gui/fonts/metron16"
   color 1 0.5 0 1
   text "0"
   "text halign" right
   "text valign" center
   "exact text" 1
   ignorepointer 1
  }
  PanelWidgetClass subCategoryContainer {
   position 0.05 1
   size 0.95 0
   color 0 0 0 0
   visible 0
   ignorepointer 0
  }
 }
}
