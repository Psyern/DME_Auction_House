  PanelWidgetClass ConfirmFrame {
   position 0.3 0.3
   size 0.4 0.25
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   color 0.05 0.05 0.05 0.97
   style DayZDefaultPanel
   {
    TextWidgetClass txtConfirmTitle {
     position 0.05 0.05
     size 0.9 0.15
