       vexactpos 0
       hexactsize 0
       vexactsize 0
       font "gui/fonts/metron16bold"
       color 0 0.8 0 1
       text "YES"
       "text halign" center
       "text valign" center
       "exact text" 1
      }
     }
    }
    ButtonWidgetClass btnConfirmNo {
     position 0.52 0.65
