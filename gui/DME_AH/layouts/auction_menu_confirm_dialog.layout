     vexactpos 0
     hexactsize 0
     vexactsize 0
     font "gui/fonts/metron16bold"
     color 1 0.5 0 1
     text "Confirm"
     "text halign" center
     "text valign" center
     "exact text" 1
    }
    TextWidgetClass txtConfirmMessage {
     position 0.05 0.25
     size 0.9 0.3
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     font "gui/fonts/metron14"
     color 0.8 0.8 0.8 1
     text "Are you sure?"
     "text halign" center
     "text valign" center
     "exact text" 1
    }
    ButtonWidgetClass btnConfirmYes {
     position 0.05 0.65
     size 0.43 0.25
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style Editor
     "no focus" 1
     {
      TextWidgetClass txtConfirmYes {
       position 0 0
       size 1 1
